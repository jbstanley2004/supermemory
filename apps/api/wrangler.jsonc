{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "supermemory-api",
  "main": "./src/server.ts",
  "compatibility_date": "2025-07-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],

  "vars": {
    "OPENAI_MODEL": "gpt-4o-mini",
    "OPENAI_EMBEDDING_MODEL": "text-embedding-3-small",
    "DB_DRIVER": "auto"
  }
}
