{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "supermemory-api",
  "main": "./src/server.ts",
  "compatibility_date": "2025-07-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "Chat",
        "class_name": "Chat"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Chat"]
    }
  ],
  "vars": {
    "OPENAI_MODEL": "gpt-4o-mini"
  }
}

