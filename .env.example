# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Database Configuration (PostgreSQL with pgvector)
# You can use Neon, Supabase, or any PostgreSQL provider that supports pgvector
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# Authentication
BETTER_AUTH_SECRET=generate_with_openssl_rand_base64_32
BETTER_AUTH_URL=https://api-supermemory.terragon.workers.dev

# Required API Keys
OPENAI_API_KEY=sk-...
RESEND_API_KEY=re_...

# Optional API Keys (for additional LLM providers)
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
GROQ_API_KEY=gsk_...

# Optional OAuth Providers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional External Connectors
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Optional Monitoring
SENTRY_DSN=

# Environment
NODE_ENV=production